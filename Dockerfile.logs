FROM python:3.13-alpine3.22@sha256:ab45bd32143151fe060d48218b91df43a289166e72ec7877823b1c972580bed3

# Install uv
COPY --from=ghcr.io/astral-sh/uv@sha256:9a23023be68b2ed09750ae636228e903a54a05ea56ed03a934d00fe9fbeded4b /uv /uvx /bin/
WORKDIR /app

# Install git for newest pymumble, which is required due to shared python dependencies with the server
RUN apk add --no-cache git

# Cache runtime Python dependencies before copying the log-tool source. This
# layer only needs to rerun when pyproject.toml or uv.lock changes, and it does
# not install prop-teststand.
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    uv sync --locked --no-install-project --no-dev

COPY pyproject.toml uv.lock hatch_build.py ./
COPY qretproptools/cli/see_logs ./qretproptools/cli/see_logs

# Copy the minimum source tree needed for the see_logs entry point. Hatchling
# package discovery still needs the package directories to exist.
RUN mkdir -p libqretprop qretproptools/cli && \
    touch libqretprop/__init__.py qretproptools/__init__.py qretproptools/cli/__init__.py

# Add config-specific files
COPY libqretprop/configManager.py ./libqretprop/configManager.py
COPY config.yaml ./config.yaml

# Install the copied log-tool project files. This image does not use the qlcp
# protocol artifacts, so skip the Hatchling protocol hook.
RUN --mount=type=cache,target=/root/.cache/uv \
    SKIP_PROTOCOL_BUILD=1 uv sync --locked --no-dev

CMD ["uv", "run", "--no-sync", "--no-dev", "see_logs", "-e", "-d", "-s", "-p"]
